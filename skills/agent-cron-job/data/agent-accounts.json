{
  "description": "Agent 到 Feishu Account ID 的映射配置",
  "mappings": {
    "main": {
      "accountId": "feishubot",
      "name": "主智能体"
    },
    "dev": {
      "accountId": "feishu-dev",
      "name": "开发智能体"
    },
    "ops": {
      "accountId": "feishu-ops",
      "name": "运维智能体"
    },
    "sop": {
      "accountId": "feishu-sop",
      "name": "SOP 智能体"
    },
    "crawler": {
      "accountId": "feishu-crawler",
      "name": "爬虫智能体"
    }
  },
  "usage": {
    "description": "在 isolated session 中使用 message 工具发送飞书消息时，需要指定 accountId 参数",
    "example": {
      "action": "send",
      "channel": "feishu",
      "accountId": "feishu-dev",
      "target": "user:ou_xxx",
      "message": "汇报内容"
    }
  }
}
